<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_review_card"
    android:padding="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/authorAvatar"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:background="@color/bookshare_avatar_placeholder"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.BookShare.Circle" />

    <TextView
        android:id="@+id/authorName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:text="Alex Reader"
        android:textColor="@color/bookshare_text_strong"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/authorAvatar"
        app:layout_constraintEnd_toStartOf="@id/dateTextView"
        app:layout_constraintStart_toEndOf="@id/authorAvatar"
        app:layout_constraintTop_toTopOf="@id/authorAvatar" />

    <TextView
        android:id="@+id/dateTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:textColor="@color/bookshare_text_muted"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="@id/authorAvatar"
        app:layout_constraintEnd_toStartOf="@id/cardMoreButton"
        app:layout_constraintTop_toTopOf="@id/authorAvatar"
        tools:text="May 25" />

    <ImageView
        android:id="@+id/cardMoreButton"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:contentDescription="More options"
        android:src="@drawable/ic_more_horiz"
        app:layout_constraintBottom_toBottomOf="@id/authorAvatar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/authorAvatar" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/bookCover"
        android:layout_width="60dp"
        android:layout_height="86dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_book_cover_dark"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/authorAvatar"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.BookShare.BookCover" />

    <TextView
        android:id="@+id/bookTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:fontFamily="sans-serif-medium"
        android:text="Project Hail Mary"
        android:textColor="@color/bookshare_text_strong"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/bookCover"
        app:layout_constraintTop_toTopOf="@id/bookCover" />

    <RatingBar
        android:id="@+id/ratingBar"
        style="?android:attr/ratingBarStyleSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="5dp"
        android:isIndicator="true"
        android:numStars="5"
        android:progressBackgroundTint="@color/bookshare_rating_empty"
        android:progressTint="@color/bookshare_rating_gold"
        android:secondaryProgressTint="@color/bookshare_rating_gold"
        android:stepSize="0.5"
        app:layout_constraintStart_toEndOf="@id/bookCover"
        app:layout_constraintTop_toBottomOf="@id/bookTitle" />

    <TextView
        android:id="@+id/reviewText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.4"
        android:maxLines="2"
        android:text="Quietly powerful and beautifully written. It stayed with me for days."
        android:textColor="@color/bookshare_text_body"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/bookCover"
        app:layout_constraintTop_toBottomOf="@id/ratingBar" />

    <TextView
        android:id="@+id/reviewToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:background="?attr/selectableItemBackground"
        android:fontFamily="sans-serif-medium"
        android:paddingVertical="2dp"
        android:text="@string/feed_card_read_more"
        android:textColor="@color/bookshare_blue"
        android:textSize="11sp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/bookCover"
        app:layout_constraintTop_toBottomOf="@id/reviewText" />

    <TextView
        android:id="@+id/viewDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="6dp"
        android:background="?attr/selectableItemBackground"
        android:fontFamily="sans-serif-medium"
        android:paddingVertical="2dp"
        android:text="@string/feed_card_view_description"
        android:textColor="@color/bookshare_blue"
        android:textSize="11sp"
        app:layout_constraintStart_toEndOf="@id/bookCover"
        app:layout_constraintTop_toBottomOf="@id/reviewToggle"
        app:layout_goneMarginTop="6dp" />


</androidx.constraintlayout.widget.ConstraintLayout>
