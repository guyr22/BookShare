<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.bookstore.ui.LoginFragment"
        android:label="Sign In"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_feed"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.bookstore.ui.RegisterFragment"
        android:label="Sign Up"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_feed"
            app:destination="@id/feedFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/feedFragment"
        android:name="com.example.bookstore.ui.FeedFragment"
        android:label="Feed"
        tools:layout="@layout/fragment_feed">
        <action
            android:id="@+id/action_feed_to_profile"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_feed_to_addEditBook"
            app:destination="@id/addEditBookFragment" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.bookstore.ui.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_addEditBook"
            app:destination="@id/addEditBookFragment" />
    </fragment>

    <fragment
        android:id="@+id/addEditBookFragment"
        android:name="com.example.bookstore.ui.AddEditBookFragment"
        android:label="Add / Edit Book"
        tools:layout="@layout/fragment_add_edit_book">
        <argument
            android:name="bookId"
            app:argType="string"
            android:defaultValue="" />
    </fragment>

</navigation>
